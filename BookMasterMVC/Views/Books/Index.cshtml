@model IEnumerable<Book>
<div class="row">
    <div class="col">
        <h2>Book Library</h2>
    </div>
</div>
    
@foreach (var book in @Model)
{
    <div class="row p-2 mb-2">
        <div class="col-sm col-md-3">
                <img src="@book.ImageLink" alt="@book.Title" class="w-100"/>
        </div>
        <div class="col-sm col-md-9">
            <p>@book.Description</p>
            <p>Quantity: <span>@book.Quantity</span></p>
            <p>Owned: <span>@(book.IsOwned ? "Yes" : "No")</span></p>
            <p>Status: <span>@(book.StatusID == 1 ? "Read" : "Want To Read")</span></p>

            <ul class="list-inline">
                <li class="list-inline-item">
                    <a href="/Books/ViewBook/@book.BookID" class="btn btn-primary">View</a>
                </li>
                <li class="list-inline-item">
                    <a href="/Books/Update/@book.BookID" class="btn btn-warning">Edit</a>
                </li>
                <li class="list-inline-item">
                    @using (Html.BeginForm("DeleteBook", "Books", FormMethod.Post))
                    {
                        <input type="hidden" asp-for="@book.BookID" />

                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this book?');">
                            Delete
                        </button>
                    }
                </li>
            </ul>
        </div>
    </div>
}