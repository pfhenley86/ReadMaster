@model VolumeInfo

@if (ViewBag.Message != null)
{
    <p>@ViewBag.Message</p>
}

<div class="container">
    <div class="col-md-12">
        <h2>Search Books</h2>
    </div>
</div>

<div class="container">
    <div class="col-md-12">
        <form method="post">
            <div class="form-group">
                <input type="search" class="form-control" name="query" placeholder="Search Title or ISBN"/>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="container">
    <div class="col-md-12">
        @if (Model != null)
        {
            <hr/>
            <h3>@Model.Title</h3>
    
            <p>
                <strong>Author:</strong>
                @Model.Author
            </p>
    
            <img src="@Model.ImageLinks?.Thumbnail" />
    
            <p>@Model.Description</p>
    
            <a class="btn btn-primary" href="/Books/InsertBook?title@Model.Title&
    author=@Model.Author?.FirstOrDefault()&
    description=@Model.Description"&
               cover="@Model.ImageLinks?.Thumbnail">
                Add Book
            </a>
        }
    </div>
</div>
