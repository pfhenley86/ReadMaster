@model Book
<div class="container">
    <div class="row">
        <div class="col">
            <h2>Update @Model.Title</h2>
        </div>
    </div>
    <div class="row">
        <div class="col">
            @using (Html.BeginForm("UpdateBookToDatabase", "Books", FormMethod.Post))
            {
                <input type="hidden" asp-for="BookID" />

                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />

                <label asp-for="Author"></label>
                <input asp-for="Author" class="form-control" />
                
                <label asp-for="Description"></label>
                <input asp-for="Description" class="form-control" />
                
                <label asp-for="ImageLink"></label>
                <input asp-for="ImageLink" class="form-control" />
                
                <label asp-for="Quantity"></label>
                <input asp-for="Quantity" class="form-control" />
                
                <div class="form-check">
                    <input asp-for="IsOwned" class="form-check-input" />
                    <label asp-for="IsOwned" class="form-check-label"></label>
                </div>
                
                <div class="form-group">
                    <label asp-for="StatusID"></label>
                    <select asp-for="StatusID" class="form-control"
                            asp-items="@(new SelectList(Model.Status, "StatusID", "StatusName", Model.StatusID))">
                    </select>
                </div>
                
                <input type="submit" value="Update Book" class="btn btn-primary" />
            }
        </div>
    </div>
</div>